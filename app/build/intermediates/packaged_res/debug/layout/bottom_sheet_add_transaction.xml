<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto" android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="vertical" android:padding="16dp" android:background="@color/surface">

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="New Transaction" android:textAppearance="@style/TextAppearance.MaterialComponents.Headline6" android:textColor="@color/textDark" android:layout_marginBottom="16dp" />

    <!-- Type toggle -->
    <com.google.android.material.button.MaterialButtonToggleGroup android:id="@+id/toggle_type" android:layout_width="match_parent" android:layout_height="wrap_content" app:singleSelection="true" app:checkedButton="@+id/btn_expense" app:selectionRequired="true">

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_income" style="@style/ToggleButton" android:layout_width="0dp" android:layout_weight="1" android:text="Income" />

        <com.google.android.material.button.MaterialButton android:id="@+id/btn_expense" style="@style/ToggleButton" android:layout_width="0dp" android:layout_weight="1" android:text="Expense" />
    </com.google.android.material.button.MaterialButtonToggleGroup>

    <!-- Main Category Spinner -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Category" android:textColor="@color/textMuted" android:layout_marginTop="16dp" android:textAppearance="@style/TextAppearance.MaterialComponents.Caption" />

    <Spinner android:id="@+id/spinner_category" android:layout_width="match_parent" android:layout_height="wrap_content" android:entries="@array/categories_list" android:padding="12dp" />

    <!-- Subcategory Spinner -->
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Subcategory" android:textColor="@color/textMuted" android:layout_marginTop="16dp" android:textAppearance="@style/TextAppearance.MaterialComponents.Caption" />

    <Spinner android:id="@+id/spinner_subcategory" android:layout_width="match_parent" android:layout_height="wrap_content" android:padding="12dp" />

    <!-- Amount -->
    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:hint="Amount (₪)">

        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_amount" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="numberDecimal" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Date -->
    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:hint="Date (yyyy-mm-dd)">

        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_date" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="date" android:focusable="false" android:clickable="true" />
    </com.google.android.material.textfield.TextInputLayout>

    <!-- Notes -->
    <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="16dp" android:hint="Notes (optional)">

        <com.google.android.material.textfield.TextInputEditText android:id="@+id/et_notes" android:layout_width="match_parent" android:layout_height="wrap_content" />
    </com.google.android.material.textfield.TextInputLayout>

    <Button android:id="@+id/btn_save" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:text="Save Transaction" android:backgroundTint="@color/primary" />
</LinearLayout>